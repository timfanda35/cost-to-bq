# Source configuration
SOURCE_TYPE=s3                    # Required: 's3' or 'azure'
SOURCE_BUCKET=my-billing-bucket   # Required: S3 bucket name or Azure container name
SOURCE_PREFIX=                    # Optional: path prefix to filter objects

# GCS staging
GCS_BUCKET=my-gcs-staging-bucket  # Required
GCS_DESTINATION_PREFIX=billing/   # Optional: path prefix in GCS (e.g. "billing/")

# BigQuery destination
BQ_PROJECT_ID=my-gcp-project      # Required
BQ_DATASET_ID=billing             # Required
BQ_TABLE_ID=daily_costs           # Required

# AWS S3 credentials (required when SOURCE_TYPE=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                # Optional: uses instance/workload identity if omitted
AWS_SECRET_ACCESS_KEY=            # Required if AWS_ACCESS_KEY_ID is set

# Azure credentials (required when SOURCE_TYPE=azure)
AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=myaccount;AccountKey=...;EndpointSuffix=core.windows.net

# Server (optional)
PORT=8080
